{
  "manifest_version": 3,
  "name": "Leetcode Tracker",
  "version": "1.0",
  "description": "A browser extension to track solved Leetcode problems in a google sheet",
  "permissions": ["unlimitedStorage", "storage"],
  "host_permissions": ["https://leetcode.com/*", "https://api.github.com/*"],
  "content_scripts": [
    {
      "matches": ["https://leetcode.com/*", "https://github.com/*"],
      "js": ["scripts/loader.js"],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "icons": {
    "48": "icons/border-48.png"
  },
  "action": {
    "default_popup": "popup.html"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "{ca2d6de6-3a5e-4ab3-afae-2ef6e1f241f0}"
    }
  }
}

